# -----------------------------------------------------------------------
# Build output directories
# -----------------------------------------------------------------------
/build/
/build-mac/
/out/
/dist/

# -----------------------------------------------------------------------
# Local credentials -- NEVER commit these
# -----------------------------------------------------------------------
.env.mac
.env

# Build log captured during development
build_output.txt

# -----------------------------------------------------------------------
# Temporary / working directories
# -----------------------------------------------------------------------
# Temporary CLAP SDK working copy — headers have been copied to include/
/_clap_tmp/

# -----------------------------------------------------------------------
# CMake generated files at the root (when cmake is run in-source)
# -----------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
_deps/

# -----------------------------------------------------------------------
# Visual Studio / MSBuild
# -----------------------------------------------------------------------
.vs/
*.vcxproj.user
*.suo
*.VC.db
*.VC.opendb
*.sdf
ipch/
*.opensdf
*.tlog
*.lastbuildstate
*.recipe

# -----------------------------------------------------------------------
# Compiled plugin output (build artifacts - not source)
# -----------------------------------------------------------------------
*.exe
*.clap
*.clap.old
*.pdb
*.ilk
*.map

# Note: libs/**/*.lib  libs/**/*.dll  libs/**/*.def  libs/**/*.exp are
# intentionally KEPT in the repository — they are pre-built import
# libraries required to compile and run the plugin on Windows and there
# is no package-manager source for them in this project.

# -----------------------------------------------------------------------
# OS-generated junk
# -----------------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
ehthumbs.db
