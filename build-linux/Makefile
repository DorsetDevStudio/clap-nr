	$(MAKE) $(MAKESILENT) -f CMakeFiles/clap-nr.dir/build.make CMakeFiles/clap-nr.dir/src/nr/zetaHat.c.o
.PHONY : src/nr/zetaHat.c.o

src/nr/zetaHat.i: src/nr/zetaHat.c.i
.PHONY : src/nr/zetaHat.i

# target to preprocess a source file
src/nr/zetaHat.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/clap-nr.dir/build.make CMakeFiles/clap-nr.dir/src/nr/zetaHat.c.i
.PHONY : src/nr/zetaHat.c.i

src/nr/zetaHat.s: src/nr/zetaHat.c.s
.PHONY : src/nr/zetaHat.s

# target to generate assembly for a file
src/nr/zetaHat.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/clap-nr.dir/build.make CMakeFiles/clap-nr.dir/src/nr/zetaHat.c.s
.PHONY : src/nr/zetaHat.c.s

